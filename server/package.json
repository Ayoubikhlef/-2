{
  "name": "aos-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "deploy": "prisma generate && prisma db push && tsx src/seed.ts && node dist/index.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/socket.io": "^3.0.1",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
