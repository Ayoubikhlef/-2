# Server (Render / local)
PORT=3001
NODE_ENV=development

# Database (PostgreSQL - get from Render Dashboard → PostgreSQL)
# Local: DATABASE_URL="postgresql://user:pass@localhost:5432/aos"
DATABASE_URL="postgresql://user:pass@host:5432/aos"

# JWT - generate random strings
JWT_SECRET="change-this-to-a-random-secret"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS - frontend URL (Vercel or local)
CORS_ORIGIN="https://aos-tech-store.vercel.app"
